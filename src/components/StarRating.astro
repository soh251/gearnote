---
interface Props {
  rating: number;
  maxRating?: number;
  showNumber?: boolean;
  size?: 'sm' | 'md' | 'lg';
}

const { rating, maxRating = 5, showNumber = true, size = 'md' } = Astro.props;

const sizePx = { sm: 16, md: 20, lg: 24 }[size];

const stars = Array.from({ length: maxRating }, (_, i) => {
  const fill = Math.min(Math.max(rating - i, 0), 1);
  if (fill >= 1) return 'full';
  if (fill >= 0.5) return 'half';
  return 'empty';
});
---

<div class="flex items-center gap-1">
  <span class="flex items-center" aria-label={`評価: ${rating}/${maxRating}`}>
    {stars.map((type) => (
      <svg
        width={sizePx}
        height={sizePx}
        viewBox="0 0 20 20"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <clipPath id="half-clip">
            <rect x="0" y="0" width="10" height="20" />
          </clipPath>
        </defs>
        {/* 背景（空の星） */}
        <polygon
          points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7"
          fill="#52525b"
        />
        {/* 塗り（全体 or 半分） */}
        {type === 'full' && (
          <polygon
            points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7"
            fill="#fbbf24"
          />
        )}
        {type === 'half' && (
          <polygon
            points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7"
            fill="#fbbf24"
            clip-path="url(#half-clip)"
          />
        )}
      </svg>
    ))}
  </span>
  {showNumber && (
    <span class="text-amber-400 font-bold ml-1">{rating.toFixed(1)}</span>
  )}
</div>
