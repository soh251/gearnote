---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title,
  description = 'ギター・音楽機材のレビューと比較情報サイト',
  image = '/logo.png',
  type = 'website',
} = Astro.props;
const siteName = 'GearNote';

// 正規URL・OGP用の絶対URLを生成（site未設定でも落ちないようフォールバック）
const siteUrl = Astro.site ?? new URL('https://gearnote-guitar.vercel.app');
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;

// サイト全体の構造化データ（WebSite + 検索ボックス + 運営者）
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl.href}#website`,
      url: siteUrl.href,
      name: siteName,
      description: 'ギター機材レビューと比較情報',
      inLanguage: 'ja',
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${siteUrl.href}search?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl.href}#organization`,
      name: siteName,
      url: siteUrl.href,
      logo: new URL('/logo.png', siteUrl).href,
    },
  ],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | {siteName}</title>
    <link rel="canonical" href={canonical} />
    <!-- OGP -->
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${siteName}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} is:inline />
    <slot name="head" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-V0SPGPCGWM"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-V0SPGPCGWM');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-[#1a1a1a] min-h-screen font-sans antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  body {
    font-family: 'Noto Sans JP', system-ui, sans-serif;
  }

  .prose {
    color: #374151;
  }

  .prose h2 {
    color: #1a1a1a;
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #f59e0b;
  }

  .prose h3 {
    color: #1a1a1a;
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose p {
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose ul li {
    margin-bottom: 0.25rem;
  }

  .prose ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose ol li {
    margin-bottom: 0.25rem;
  }

  .prose strong {
    color: #1a1a1a;
    font-weight: 700;
  }

  .prose a {
    color: #d97706;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #b45309;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prose table {
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    min-width: 480px;
    width: 100%;
  }

  .prose th {
    background: #FFF3E0;
    color: #1a1a1a;
    font-weight: 600;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border: 1px solid #e5e7eb;
    white-space: nowrap;
  }

  .prose td {
    padding: 0.5rem 0.75rem;
    border: 1px solid #e5e7eb;
    color: #374151;
    font-size: 0.9rem;
  }

  .prose tr:nth-child(even) td {
    background: #f9fafb;
  }
</style>
