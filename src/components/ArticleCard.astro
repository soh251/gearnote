---
import StarRating from './StarRating.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  publishedAt: string;
  slug: string;
  rating?: number;
  featured?: boolean;
  thumbnail?: string;
}

const { title, description, category, publishedAt, slug, rating, featured, thumbnail } = Astro.props;

const categoryLabels: Record<string, string> = {
  'electric-guitar': 'エレキギター',
  'acoustic-guitar': 'アコースティックギター',
  'effector': 'エフェクター',
  'amp': 'アンプ',
  'dtm': 'DTM機材',
  'beginners-guide': '初心者ガイド',
};

const categoryColors: Record<string, string> = {
  'electric-guitar': 'bg-blue-100 text-blue-700 border-blue-200',
  'acoustic-guitar': 'bg-emerald-100 text-emerald-700 border-emerald-200',
  'effector': 'bg-purple-100 text-purple-700 border-purple-200',
  'amp': 'bg-red-100 text-red-700 border-red-200',
  'dtm': 'bg-cyan-100 text-cyan-700 border-cyan-200',
  'beginners-guide': 'bg-amber-100 text-amber-700 border-amber-200',
};

const categoryDefaultImages: Record<string, string> = {
  'electric-guitar': '/images/electric-guitar.jpg',
  'acoustic-guitar': '/images/acoustic-guitar.jpg',
  'effector': '/images/effector.jpg',
  'amp': '/images/electric-guitar.jpg',
  'dtm': '/images/dtm.jpg',
  'beginners-guide': '/images/electric-guitar.jpg',
};

const imageUrl = thumbnail ?? categoryDefaultImages[category];
---

<a
  href={`/articles/${slug}`}
  class="group block bg-[#f5f5f5] border border-[#e5e7eb] rounded-xl overflow-hidden hover:border-amber-400 hover:shadow-md transition-all duration-200"
>
  {imageUrl && (
    <div class="overflow-hidden h-44">
      <img
        src={imageUrl}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}
  <div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-3">
      <span class={`text-xs font-medium px-2 py-1 rounded-full border ${categoryColors[category] ?? 'bg-gray-100 text-gray-600 border-gray-200'}`}>
        {categoryLabels[category] ?? category}
      </span>
      {featured && (
        <span class="text-xs font-bold px-2 py-1 rounded-full bg-amber-100 text-amber-700 border border-amber-200">
          注目
        </span>
      )}
    </div>
    <h3 class="text-[#1a1a1a] font-semibold text-base leading-snug mb-2 group-hover:text-amber-600 transition-colors duration-150 line-clamp-2">
      {title}
    </h3>
    <p class="text-[#6b7280] text-sm leading-relaxed mb-3 line-clamp-2">{description}</p>
    <div class="flex items-center justify-between">
      {rating && <StarRating rating={rating} size="sm" />}
      <time class="text-[#6b7280] text-xs ml-auto">{publishedAt}</time>
    </div>
  </div>
</a>
