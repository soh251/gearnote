---
import BaseLayout from './BaseLayout.astro';
import StarRating from '../components/StarRating.astro';
import ProductCard from '../components/ProductCard.astro';
import SpecTable from '../components/SpecTable.astro';

interface Product {
  name: string;
  price: string;
  amazonUrl?: string;
  soundhouseUrl?: string;
  image?: string;
  specs?: Record<string, string>;
}

interface Props {
  title: string;
  description: string;
  category: string;
  publishedAt: string;
  rating?: number;
  products?: Product[];
}

const { title, description, category, publishedAt, rating, products } = Astro.props;

const categoryLabels: Record<string, string> = {
  'electric-guitar': 'エレキギター',
  'acoustic-guitar': 'アコースティックギター',
  'effector': 'エフェクター',
  'amp': 'アンプ',
  'dtm': 'DTM機材',
  'beginners-guide': '初心者ガイド',
};

const productsWithSpecs = products?.filter((p) => p.specs && Object.keys(p.specs).length > 0) ?? [];
---

<BaseLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-2">
      <a href={`/category/${category}`} class="text-amber-600 hover:text-amber-500 text-sm transition-colors">
        ← {categoryLabels[category] ?? category}
      </a>
    </div>

    <h1 class="text-2xl md:text-3xl font-bold text-[#1a1a1a] leading-tight mb-4">{title}</h1>

    <div class="flex flex-wrap items-center gap-4 mb-8 pb-8 border-b border-[#e5e7eb]">
      {rating && <StarRating rating={rating} size="md" />}
      <time class="text-[#6b7280] text-sm">{publishedAt}</time>
    </div>

    {products && products.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-bold text-[#1a1a1a] mb-4 flex items-center gap-2">
          <span class="w-1 h-5 bg-amber-500 rounded-full inline-block"></span>
          紹介商品
        </h2>
        <div class={`grid gap-4 ${products.length === 1 ? 'grid-cols-1 max-w-xs' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {products.map((product) => (
            <ProductCard
              name={product.name}
              price={product.price}
              amazonUrl={product.amazonUrl}
              soundhouseUrl={product.soundhouseUrl}
              ikebeUrl={product.ikebeUrl}
              ishibashiUrl={product.ishibashiUrl}
              image={product.image}
            />
          ))}
        </div>
      </section>
    )}

    {productsWithSpecs.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-bold text-[#1a1a1a] mb-4 flex items-center gap-2">
          <span class="w-1 h-5 bg-amber-500 rounded-full inline-block"></span>
          スペック比較
        </h2>
        <SpecTable products={productsWithSpecs.map((p) => ({ name: p.name, specs: p.specs! }))} />
      </section>
    )}

    <article class="prose max-w-none">
      <slot />
    </article>

    {products && products.length > 0 && (
      <div class="mt-12 p-6 bg-[#f5f5f5] border border-[#e5e7eb] rounded-xl">
        <h3 class="text-[#1a1a1a] font-bold mb-4">購入リンク</h3>
        <div class={`grid gap-4 ${products.length === 1 ? 'grid-cols-1 max-w-xs' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {products.map((product) => (
            <ProductCard
              name={product.name}
              price={product.price}
              amazonUrl={product.amazonUrl}
              soundhouseUrl={product.soundhouseUrl}
              ikebeUrl={product.ikebeUrl}
              ishibashiUrl={product.ishibashiUrl}
              image={product.image}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
