---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles');

function isGuideArticle(id: string): boolean {
  const filename = id.split('/').pop() ?? '';
  return id.includes('/hub/')
    || id.includes('/category/')
    || filename.endsWith('-guide')
    || filename.includes('-comparison')
    || filename.includes('-vs-');
}

function getGuideType(id: string): 'guide' | 'matome' {
  if (id.includes('/hub/')) return 'guide';
  if (id.includes('/category/')) return 'matome';
  const filename = id.split('/').pop() ?? '';
  if (filename.includes('-vs-') || filename.includes('-comparison') || filename.includes('category-guide')) return 'matome';
  return 'guide';
}

function guidePriority(article: (typeof allArticles)[number]): number {
  const filename = article.id.split('/').pop() ?? '';
  if (article.data.category === 'beginners-guide') return 0;
  if (filename.includes('category-guide')) return 1;
  if (filename.includes('-vs-') || filename.includes('-comparison')) return 2;
  if (article.id.includes('/hub/')) return 3;
  if (article.id.includes('/category/')) return 4;
  return 5;
}

const guideArticles = allArticles
  .filter((a) => isGuideArticle(a.id))
  .sort((a, b) => {
    const pd = guidePriority(a) - guidePriority(b);
    if (pd !== 0) return pd;
    return new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime();
  })
  .slice(0, 9);

const recentArticles = [...allArticles]
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 12);
---

<BaseLayout title="GearNote — ギター機材レビューと比較情報" description="GearNote — ギター機材レビューと比較情報。エレキギター・エフェクター・アンプ・DTM機材のレビューと比較情報をお届け。初心者から中級者まで最適な機材選びをサポートします。">
  <!-- サイト説明バー -->
  <div class="border-b border-[#e5e7eb] bg-white">
    <div class="max-w-6xl mx-auto px-4 py-2 flex items-center justify-between">
      <p class="text-[#6b7280] text-xs">GearNote — ギター機材レビューと比較情報</p>
      <span class="text-[#6b7280] text-xs">{allArticles.length}件のレビュー掲載中</span>
    </div>
  </div>

  <!-- 初心者はここから -->
  {guideArticles.length > 0 && (
    <div class="bg-white border-b border-[#e5e7eb]">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-1 h-4 rounded-full inline-block" style="background:#E65100;"></span>
          <h2 class="text-sm font-bold text-[#1a1a1a] tracking-wide">初心者はここから</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {guideArticles.map((article) => {
            const type = getGuideType(article.id);
            return (
              <a
                href={`/articles/${article.id}`}
                class="group flex items-start gap-3 p-4 bg-white border border-[#e5e7eb] rounded-lg hover:border-amber-400 hover:shadow-sm transition-all duration-150"
              >
                <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background:#FFF3E0;">
                  {type === 'guide' ? (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#E65100" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 7l6-3 6 3 6-3v13l-6 3-6-3-6 3z"/><path d="M9 4v13"/><path d="M15 7v13"/>
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#E65100" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
                      <circle cx="3" cy="6" r="0.5" fill="#E65100"/><circle cx="3" cy="12" r="0.5" fill="#E65100"/><circle cx="3" cy="18" r="0.5" fill="#E65100"/>
                    </svg>
                  )}
                </div>
                <div class="min-w-0">
                  <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full mb-1.5" style="background:#FFF3E0; color:#E65100;">
                    {type === 'guide' ? 'ガイド' : 'まとめ'}
                  </span>
                  <h3 class="text-sm font-semibold text-[#1a1a1a] group-hover:text-amber-600 transition-colors line-clamp-2 leading-snug">
                    {article.data.title}
                  </h3>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- 新着レビュー -->
  <div class="bg-white">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="w-1 h-4 bg-amber-500 rounded-full inline-block"></span>
        <h2 class="text-sm font-bold text-[#1a1a1a] tracking-wide">新着レビュー</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            category={article.data.category}
            publishedAt={article.data.publishedAt}
            slug={article.id}
            rating={article.data.rating}
            thumbnail={article.data.thumbnail}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
