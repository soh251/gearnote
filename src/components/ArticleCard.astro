---
interface Props {
  title: string;
  description: string;
  category: string;
  publishedAt?: string;
  slug: string;
  rating?: number;
  featured?: boolean;
  thumbnail?: string;
}

const { title, category, slug, thumbnail } = Astro.props;

const categoryLabels: Record<string, string> = {
  'electric-guitar': 'エレキギター',
  'acoustic-guitar': 'アコースティックギター',
  'effector': 'エフェクター',
  'amp': 'アンプ',
  'dtm': 'DTM機材',
  'beginners-guide': '初心者ガイド',
};

const categoryColors: Record<string, string> = {
  'electric-guitar': 'bg-blue-50 text-blue-700 border-blue-200',
  'acoustic-guitar': 'bg-emerald-50 text-emerald-700 border-emerald-200',
  'effector': 'bg-purple-50 text-purple-700 border-purple-200',
  'amp': 'bg-red-50 text-red-700 border-red-200',
  'dtm': 'bg-cyan-50 text-cyan-700 border-cyan-200',
  'beginners-guide': 'bg-amber-50 text-amber-700 border-amber-200',
};

const categoryDefaultImages: Record<string, string> = {
  'electric-guitar': '/images/electric-guitar.jpg',
  'acoustic-guitar': '/images/acoustic-guitar.jpg',
  'effector': '/images/effector.jpg',
  'amp': '/images/electric-guitar.jpg',
  'dtm': '/images/dtm.jpg',
  'beginners-guide': '/images/electric-guitar.jpg',
};

const imageUrl = thumbnail ?? categoryDefaultImages[category];
---

<a
  href={`/articles/${slug}`}
  class="group block bg-white border border-[#e5e7eb] rounded-lg overflow-hidden hover:border-amber-400 hover:shadow-sm transition-all duration-150"
>
  {imageUrl && (
    <div class="overflow-hidden h-36">
      <img
        src={imageUrl}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}
  <div class="p-3">
    <div class="mb-1.5">
      <span class={`text-xs font-medium px-1.5 py-0.5 rounded border ${categoryColors[category] ?? 'bg-gray-50 text-gray-600 border-gray-200'}`}>
        {categoryLabels[category] ?? category}
      </span>
    </div>
    <h3 class="text-[#1a1a1a] font-semibold text-sm leading-snug group-hover:text-amber-600 transition-colors duration-150 line-clamp-2">
      {title}
    </h3>
  </div>
</a>
