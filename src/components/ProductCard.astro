---
interface Props {
  name: string;
  price: string;
  amazonUrl?: string;
  soundhouseUrl?: string;
  ikebeUrl?: string;
  ishibashiUrl?: string;
  image?: string;
}

const { name, price, amazonUrl, soundhouseUrl, ikebeUrl, ishibashiUrl, image } = Astro.props;

// --- サウンドハウスのリンク生成 ---
// 承認後: SOUNDHOUSE_AFFILIATE_ID に実IDを入れ、wrapSoundhouse() でラップするだけで全ボタンが一斉にアフィリ化される。
// 現状: 通常（非アフィリエイト）の検索リンク。プレースホルダー or 未設定の商品は商品名から検索URLを自動生成。
const SOUNDHOUSE_AFFILIATE_ID = ''; // ← 承認が下りたらここにIDを設定

const cleanName = (n: string) =>
  n.replace(/[（(][^）)]*[）)]/g, '').replace(/\s+/g, ' ').trim();

const soundhouseSearchUrl = (keyword: string) =>
  `https://www.soundhouse.co.jp/search/index?search_all=${encodeURIComponent(keyword)}&i_type=a`;

const wrapSoundhouse = (url: string) =>
  SOUNDHOUSE_AFFILIATE_ID ? url /* TODO: 承認後にアフィリパラメータを付与 */ : url;

const realSoundhouse =
  soundhouseUrl && !soundhouseUrl.startsWith('[AFFILIATE_SOUNDHOUSE') ? soundhouseUrl : null;
const soundhouseLink = wrapSoundhouse(realSoundhouse ?? soundhouseSearchUrl(cleanName(name)));

const primaryCount = (amazonUrl ? 1 : 0) + (soundhouseLink ? 1 : 0);
const hasUsed = Boolean(ikebeUrl || ishibashiUrl);
const REL = 'sponsored noopener noreferrer';
---

<div class="bg-[#f5f5f5] border border-[#e5e7eb] rounded-xl overflow-hidden hover:border-amber-400 hover:shadow-md transition-all duration-200">
  {image ? (
    <div class="bg-white flex items-center justify-center h-48 p-4">
      <img src={image} alt={name} loading="lazy" class="h-full w-full object-contain" />
    </div>
  ) : (
    <div class="w-full h-48 bg-[#e5e7eb] flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-[#6b7280]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
      </svg>
    </div>
  )}
  <div class="p-4">
    <h3 class="text-[#1a1a1a] font-semibold text-sm leading-snug mb-2">{name}</h3>
    <p class="text-amber-600 font-bold text-lg mb-3">{price}</p>

    {/* 新品（メインCTA：Amazon × サウンドハウスの2連ボタン） */}
    {primaryCount > 0 && (
      <div class={primaryCount === 2 ? 'grid grid-cols-2 gap-2' : 'grid grid-cols-1 gap-2'}>
        {amazonUrl && (
          <a
            href={amazonUrl}
            target="_blank"
            rel={REL}
            class="flex items-center justify-center gap-1.5 bg-[#FF9900] hover:bg-[#e88a00] text-[#1a1a1a] font-bold text-sm py-3 px-3 rounded-lg transition-colors duration-150 shadow-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 14.5c-1.26.91-2.99 1.5-4.5 1.5-3.59 0-6.5-2.91-6.5-6.5 0-1.51.52-2.91 1.38-4.02l.88.88C7.26 9.21 7 10.07 7 11c0 2.76 2.24 5 5 5 .93 0 1.79-.26 2.54-.68l.96.68z"/></svg>
            Amazon
          </a>
        )}
        {soundhouseLink && (
          <a
            href={soundhouseLink}
            target="_blank"
            rel={REL}
            class="flex items-center justify-center gap-1.5 bg-[#1f6fd6] hover:bg-[#1a5cb3] text-white font-bold text-sm py-3 px-3 rounded-lg transition-colors duration-150 shadow-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
            サウンドハウス
          </a>
        )}
      </div>
    )}

    {/* 中古（サブ：イケベ・イシバシ） */}
    {hasUsed && (
      <>
        <p class="text-[11px] text-[#9ca3af] mt-3 mb-1.5">中古を探す</p>
        <div class={ikebeUrl && ishibashiUrl ? 'grid grid-cols-2 gap-2' : 'grid grid-cols-1 gap-2'}>
          {ikebeUrl && (
            <a
              href={ikebeUrl}
              target="_blank"
              rel={REL}
              class="flex items-center justify-center gap-1 bg-white hover:bg-[#f5f5f5] text-[#4b5563] font-medium text-xs py-2 px-2 rounded-lg transition-colors duration-150 border border-[#e5e7eb]"
            >
              イケベ楽器
            </a>
          )}
          {ishibashiUrl && (
            <a
              href={ishibashiUrl}
              target="_blank"
              rel={REL}
              class="flex items-center justify-center gap-1 bg-white hover:bg-[#f5f5f5] text-[#4b5563] font-medium text-xs py-2 px-2 rounded-lg transition-colors duration-150 border border-[#e5e7eb]"
            >
              イシバシ楽器
            </a>
          )}
        </div>
      </>
    )}
  </div>
</div>
