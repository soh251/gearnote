---
import BaseLayout from './BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import SpecTable from '../components/SpecTable.astro';
import ArticleCard from '../components/ArticleCard.astro';

interface Product {
  name: string;
  price: string;
  amazonUrl?: string;
  soundhouseUrl?: string;
  image?: string;
  specs?: Record<string, string>;
}

interface RelatedArticle {
  slug: string;
  title: string;
  description: string;
  category: string;
  thumbnail?: string;
}

interface Props {
  title: string;
  description: string;
  category: string;
  publishedAt: string;
  rating?: number;
  thumbnail?: string;
  products?: Product[];
  keywords?: string[];
  related?: RelatedArticle[];
}

const { title, description, category, publishedAt, rating, thumbnail, products, keywords, related } = Astro.props;

const categoryLabels: Record<string, string> = {
  'electric-guitar': 'エレキギター',
  'acoustic-guitar': 'アコースティックギター',
  'effector': 'エフェクター',
  'amp': 'アンプ',
  'dtm': 'DTM機材',
  'beginners-guide': '初心者ガイド',
};

const productsWithSpecs = products?.filter((p) => p.specs && Object.keys(p.specs).length > 0) ?? [];

// --- 構造化データ（JSON-LD） ---
const siteUrl = Astro.site ?? new URL('https://gearnote-guitar.vercel.app');
const articleUrl = new URL(Astro.url.pathname, siteUrl).href;
const categoryLabel = categoryLabels[category] ?? category;
const abs = (u?: string) =>
  u ? (u.startsWith('http') ? u : new URL(u, siteUrl).href) : new URL('/logo.png', siteUrl).href;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: abs(thumbnail),
  datePublished: publishedAt,
  dateModified: publishedAt,
  inLanguage: 'ja',
  mainEntityOfPage: articleUrl,
  author: { '@type': 'Organization', name: 'GearNote', url: siteUrl.href },
  publisher: {
    '@type': 'Organization',
    name: 'GearNote',
    logo: { '@type': 'ImageObject', url: new URL('/logo.png', siteUrl).href },
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl.href },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: new URL(`/category/${category}`, siteUrl).href },
    { '@type': 'ListItem', position: 3, name: title, item: articleUrl },
  ],
};

// 単体レビュー（商品1点 ＋ 評価あり）のときだけ Product+Review を出す（★スニペット狙い・ガイドライン準拠）
const single = products && products.length === 1 ? products[0] : null;
const productLd =
  single && rating
    ? {
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: single.name,
        image: abs(single.image ?? thumbnail),
        description,
        review: {
          '@type': 'Review',
          reviewRating: { '@type': 'Rating', ratingValue: rating, bestRating: 5 },
          author: { '@type': 'Organization', name: 'GearNote' },
        },
      }
    : null;

const jsonLdBlocks = [articleLd, breadcrumbLd, ...(productLd ? [productLd] : [])];
---

<BaseLayout title={title} description={description} image={abs(thumbnail)} type="article">
  <Fragment slot="head">
    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} is:inline />
    ))}
  </Fragment>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-2">
      <a href={`/category/${category}`} class="text-amber-600 hover:text-amber-500 text-sm transition-colors">
        ← {categoryLabels[category] ?? category}
      </a>
    </div>

    <h1 class="text-2xl md:text-3xl font-bold text-[#1a1a1a] leading-tight mb-4 pb-4 border-b border-[#e5e7eb]">{title}</h1>

    <p class="text-xs text-[#9ca3af] mb-8">※本記事はアフィリエイト広告を含みます。</p>

    {products && products.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-bold text-[#1a1a1a] mb-4 flex items-center gap-2">
          <span class="w-1 h-5 bg-amber-500 rounded-full inline-block"></span>
          紹介商品
        </h2>
        <div class={`grid gap-4 ${products.length === 1 ? 'grid-cols-1 max-w-xs' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {products.map((product) => (
            <ProductCard
              name={product.name}
              price={product.price}
              amazonUrl={product.amazonUrl}
              soundhouseUrl={product.soundhouseUrl}
              ikebeUrl={product.ikebeUrl}
              ishibashiUrl={product.ishibashiUrl}
              image={product.image}
            />
          ))}
        </div>
      </section>
    )}

    {productsWithSpecs.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-bold text-[#1a1a1a] mb-4 flex items-center gap-2">
          <span class="w-1 h-5 bg-amber-500 rounded-full inline-block"></span>
          スペック比較
        </h2>
        <SpecTable products={productsWithSpecs.map((p) => ({ name: p.name, specs: p.specs! }))} />
      </section>
    )}

    {keywords && keywords.length > 0 && (
      <div class="sr-only" aria-hidden="true" data-nosnippet>
        {[...new Set(keywords.join(' ').split(/\s+/).filter(Boolean))].join(' ')}
      </div>
    )}

    <article class="prose max-w-none">
      <slot />
    </article>

    <script>
      document.querySelectorAll('article.prose a[href^="http"]').forEach((a) => {
        a.setAttribute('target', '_blank');
        a.setAttribute('rel', 'noopener noreferrer nofollow');
      });
    </script>

    {products && products.length > 0 && (
      <div class="mt-12 p-6 bg-[#f5f5f5] border border-[#e5e7eb] rounded-xl">
        <h3 class="text-[#1a1a1a] font-bold mb-4">購入リンク</h3>
        <div class={`grid gap-4 ${products.length === 1 ? 'grid-cols-1 max-w-xs' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {products.map((product) => (
            <ProductCard
              name={product.name}
              price={product.price}
              amazonUrl={product.amazonUrl}
              soundhouseUrl={product.soundhouseUrl}
              ikebeUrl={product.ikebeUrl}
              ishibashiUrl={product.ishibashiUrl}
              image={product.image}
            />
          ))}
        </div>
      </div>
    )}

    {related && related.length > 0 && (
      <section class="mt-14 pt-8 border-t border-[#e5e7eb]">
        <h2 class="text-lg font-bold text-[#1a1a1a] mb-4 flex items-center gap-2">
          <span class="w-1 h-5 bg-amber-500 rounded-full inline-block"></span>
          あわせて読みたい
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {related.map((r) => (
            <ArticleCard
              title={r.title}
              description={r.description}
              category={r.category}
              slug={r.slug}
              thumbnail={r.thumbnail}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
