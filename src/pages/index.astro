---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const recentArticles = sortedArticles.slice(0, 12);

const categories = [
  { id: 'electric-guitar', label: 'エレキギター' },
  { id: 'acoustic-guitar', label: 'アコースティック' },
  { id: 'effector', label: 'エフェクター' },
  { id: 'amp', label: 'アンプ' },
  { id: 'dtm', label: 'DTM機材' },
];
---

<BaseLayout title="楽器・音楽機材レビュー&比較" description="ギター・エフェクター・DTM機材のレビューと比較情報をお届け。初心者から中級者まで最適な機材選びをサポートします。">
  <!-- サイト説明バー -->
  <div class="border-b border-[#e5e7eb] bg-white">
    <div class="max-w-6xl mx-auto px-4 py-2 flex items-center justify-between">
      <p class="text-[#6b7280] text-xs">ギター・エフェクター・DTM機材のレビューと比較情報をお届け</p>
      <span class="text-[#6b7280] text-xs">{allArticles.length}件のレビュー掲載中</span>
    </div>
  </div>

  <!-- カテゴリタブ -->
  <div class="border-b border-[#e5e7eb] bg-white sticky top-0 z-10 shadow-sm">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex overflow-x-auto -mb-px" style="scrollbar-width:none;">
        {categories.map((cat) => (
          <a
            href={`/category/${cat.id}`}
            class="shrink-0 px-4 py-3 text-sm font-medium text-[#444] hover:text-amber-600 border-b-2 border-transparent hover:border-amber-500 transition-colors whitespace-nowrap"
          >
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- 新着レビュー -->
  <div class="bg-white">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="w-1 h-4 bg-amber-500 rounded-full inline-block"></span>
        <h2 class="text-sm font-bold text-[#1a1a1a] tracking-wide">新着レビュー</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            category={article.data.category}
            publishedAt={article.data.publishedAt}
            slug={article.id}
            rating={article.data.rating}
            thumbnail={article.data.thumbnail}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
