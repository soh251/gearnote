---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featuredArticles = sortedArticles.filter((a) => a.data.featured).slice(0, 3);
const recentArticles = sortedArticles.slice(0, 6);

const categories = [
  {
    id: 'electric-guitar',
    label: 'エレキギター',
    icon: '🎸',
    description: 'ストラト・レスポール・テレキャスなど',
    color: 'from-blue-600/20 to-blue-800/10 border-blue-600/30 hover:border-blue-500',
  },
  {
    id: 'acoustic-guitar',
    label: 'アコースティックギター',
    icon: '🪕',
    description: 'ドレッドノート・トラベルギターなど',
    color: 'from-emerald-600/20 to-emerald-800/10 border-emerald-600/30 hover:border-emerald-500',
  },
  {
    id: 'effector',
    label: 'エフェクター',
    icon: '🎛️',
    description: 'ディストーション・コーラス・遅延など',
    color: 'from-purple-600/20 to-purple-800/10 border-purple-600/30 hover:border-purple-500',
  },
  {
    id: 'amp',
    label: 'アンプ',
    icon: '🔊',
    description: 'コンボ・ヘッドアンプ・キャビネット',
    color: 'from-red-600/20 to-red-800/10 border-red-600/30 hover:border-red-500',
  },
  {
    id: 'dtm',
    label: 'DTM機材',
    icon: '🎹',
    description: 'オーディオI/F・MIDIキーボードなど',
    color: 'from-cyan-600/20 to-cyan-800/10 border-cyan-600/30 hover:border-cyan-500',
  },
  {
    id: 'beginners-guide',
    label: '初心者ガイド',
    icon: '📖',
    description: '機材選び・練習方法・セッティング',
    color: 'from-amber-600/20 to-amber-800/10 border-amber-600/30 hover:border-amber-500',
  },
];
---

<BaseLayout title="楽器・音楽機材レビュー&比較" description="ギター・エフェクター・DTM機材のレビューと比較情報をお届け。初心者から中級者まで最適な機材選びをサポートします。">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-zinc-900 via-zinc-950 to-zinc-900 border-b border-zinc-800">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-amber-900/20 via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-blue-900/10 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-4 py-20 md:py-28 relative">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-amber-500/10 border border-amber-500/30 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
          <span class="text-amber-400 text-sm font-medium">楽器・音楽機材レビューサイト</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-4">
          最高の機材を、<br />
          <span class="text-amber-400">正しく選ぶ</span>ために。
        </h1>
        <p class="text-zinc-400 text-lg leading-relaxed mb-8">
          ギター・エフェクター・DTM機材の実機レビューと詳細な比較情報をお届け。
          初心者から中級者まで、あなたにぴったりの機材選びをサポートします。
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/category/electric-guitar"
            class="bg-amber-500 hover:bg-amber-400 text-zinc-900 font-bold px-6 py-3 rounded-xl transition-colors duration-150"
          >
            レビューを見る
          </a>
          <a
            href="/category/beginners-guide"
            class="bg-zinc-800 hover:bg-zinc-700 text-white font-medium px-6 py-3 rounded-xl border border-zinc-700 transition-colors duration-150"
          >
            初心者ガイド
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- カテゴリ -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-white mb-8">カテゴリから探す</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {categories.map((cat) => (
        <a
          href={`/category/${cat.id}`}
          class={`group bg-gradient-to-br ${cat.color} border rounded-xl p-5 transition-all duration-200 hover:-translate-y-0.5`}
        >
          <span class="text-3xl block mb-3">{cat.icon}</span>
          <h3 class="text-white font-semibold text-sm mb-1 group-hover:text-amber-400 transition-colors">{cat.label}</h3>
          <p class="text-zinc-500 text-xs leading-relaxed">{cat.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- 注目記事 -->
  {featuredArticles.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 pb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">注目レビュー</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {featuredArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            category={article.data.category}
            publishedAt={article.data.publishedAt}
            slug={article.id}
            rating={article.data.rating}
            featured={article.data.featured}
          />
        ))}
      </div>
    </section>
  )}

  <!-- 新着記事 -->
  <section class="max-w-6xl mx-auto px-4 pb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-white">新着記事</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {recentArticles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          category={article.data.category}
          publishedAt={article.data.publishedAt}
          slug={article.id}
          rating={article.data.rating}
          featured={article.data.featured}
        />
      ))}
    </div>
  </section>
</BaseLayout>
