---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const categories = [
    'electric-guitar',
    'acoustic-guitar',
    'effector',
    'amp',
    'dtm',
    'beginners-guide',
  ];
  return categories.map((category) => ({ params: { category } }));
}

const { category } = Astro.params;

const categoryInfo: Record<string, { label: string; description: string; icon: string }> = {
  'electric-guitar': {
    label: 'エレキギター',
    description: 'ストラト・レスポール・テレキャスターなど、エレキギターのレビューと比較',
    icon: '🎸',
  },
  'acoustic-guitar': {
    label: 'アコースティックギター',
    description: 'ドレッドノート・コンサートボディ・トラベルギターなどのレビューと比較',
    icon: '🪕',
  },
  'effector': {
    label: 'エフェクター',
    description: 'ディストーション・オーバードライブ・コーラス・ディレイなどのレビューと比較',
    icon: '🎛️',
  },
  'amp': {
    label: 'アンプ',
    description: 'コンボアンプ・ヘッドアンプ・キャビネットなどのレビューと比較',
    icon: '🔊',
  },
  'dtm': {
    label: 'DTM機材',
    description: 'オーディオインターフェース・MIDIキーボード・モニタースピーカーなどのレビューと比較',
    icon: '🎹',
  },
  'beginners-guide': {
    label: '初心者ガイド',
    description: '機材の選び方・練習方法・セッティングなど初心者向けの情報',
    icon: '📖',
  },
};

const info = categoryInfo[category!] ?? { label: category, description: '', icon: '🎵' };

function isGuideArticle(id: string): boolean {
  const filename = id.split('/').pop() ?? '';
  return id.includes('/hub/')
    || id.includes('/category/')
    || filename.endsWith('-guide')
    || filename.includes('-comparison')
    || filename.includes('-vs-');
}

function getGuideType(id: string): 'guide' | 'matome' {
  if (id.includes('/hub/')) return 'guide';
  if (id.includes('/category/')) return 'matome';
  const filename = id.split('/').pop() ?? '';
  if (filename.includes('-vs-') || filename.includes('-comparison') || filename.includes('category-guide')) return 'matome';
  return 'guide';
}

const allArticles = await getCollection('articles');

function isAnyGuideArticle(id: string): boolean {
  const filename = id.split('/').pop() ?? '';
  return id.includes('/hub/')
    || id.includes('/category/')
    || filename.endsWith('-guide')
    || filename.includes('-comparison')
    || filename.includes('-vs-');
}

const articles = allArticles
  .filter((a) => {
    if (category === 'beginners-guide') {
      return a.data.category === 'beginners-guide' || isAnyGuideArticle(a.id);
    }
    return a.data.category === category;
  })
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const guideArticles = articles.filter((a) => isGuideArticle(a.id));
const reviewArticles = articles.filter((a) => !isGuideArticle(a.id));
---

<BaseLayout title={info.label} description={info.description}>
  <!-- カテゴリヘッダー -->
  <div style="background:#FFF3E0; border-bottom:1px solid #FFCC80;">
    <div class="max-w-6xl mx-auto px-4 py-6">
      <a href="/" class="text-xs transition-colors mb-3 inline-block" style="color:#E65100;">← トップへ</a>
      <div class="flex items-center gap-3">
        <span class="text-4xl">{info.icon}</span>
        <div>
          <h1 class="text-2xl font-black text-[#1a1a1a]">{info.label}</h1>
          <p class="text-[#6b7280] text-sm mt-0.5">{info.description}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    {articles.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-[#6b7280] text-lg">まだ記事がありません</p>
        <a href="/" class="mt-4 inline-block transition-colors" style="color:#E65100;">トップに戻る</a>
      </div>
    ) : (
      <>
        {/* まず読みたい記事 */}
        {guideArticles.length > 0 && (
          <div class="mb-10">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-1 h-4 rounded-full inline-block" style="background:#E65100;"></span>
              <h2 class="text-sm font-bold text-[#1a1a1a] tracking-wide">まず読みたい記事</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {guideArticles.map((article) => {
                const type = getGuideType(article.id);
                return (
                  <a
                    href={`/articles/${article.id}`}
                    class="group flex items-start gap-3 p-4 bg-white border border-[#e5e7eb] rounded-lg hover:border-amber-400 hover:shadow-sm transition-all duration-150"
                  >
                    <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background:#FFF3E0;">
                      {type === 'guide' ? (
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#E65100" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M3 7l6-3 6 3 6-3v13l-6 3-6-3-6 3z"/><path d="M9 4v13"/><path d="M15 7v13"/>
                        </svg>
                      ) : (
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#E65100" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
                          <circle cx="3" cy="6" r="0.5" fill="#E65100"/><circle cx="3" cy="12" r="0.5" fill="#E65100"/><circle cx="3" cy="18" r="0.5" fill="#E65100"/>
                        </svg>
                      )}
                    </div>
                    <div class="min-w-0">
                      <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full mb-1.5" style="background:#FFF3E0; color:#E65100;">
                        {type === 'guide' ? 'ガイド' : 'まとめ'}
                      </span>
                      <h3 class="text-sm font-semibold text-[#1a1a1a] group-hover:text-amber-600 transition-colors line-clamp-2 leading-snug">
                        {article.data.title}
                      </h3>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {/* 個別レビュー */}
        {reviewArticles.length > 0 && (
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="w-1 h-4 bg-amber-500 rounded-full inline-block"></span>
              <h2 class="text-sm font-bold text-[#1a1a1a] tracking-wide">個別レビュー</h2>
              <span class="text-xs text-[#9ca3af]">{reviewArticles.length}件</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {reviewArticles.map((article) => (
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  category={article.data.category}
                  publishedAt={article.data.publishedAt}
                  slug={article.id}
                  rating={article.data.rating}
                  featured={article.data.featured}
                  thumbnail={article.data.thumbnail}
                />
              ))}
            </div>
          </div>
        )}
      </>
    )}
  </div>
</BaseLayout>
