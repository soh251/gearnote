---
interface Product {
  name: string;
  specs: Record<string, string>;
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;

const allKeys = [...new Set(products.flatMap((p) => Object.keys(p.specs ?? {})))];
---

<div class="overflow-x-auto rounded-xl border border-zinc-700">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-zinc-800 border-b border-zinc-700">
        <th class="text-left py-3 px-4 text-zinc-400 font-medium w-32">スペック</th>
        {products.map((p) => (
          <th class="text-left py-3 px-4 text-amber-400 font-semibold">{p.name}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {allKeys.map((key, i) => (
        <tr class={`border-b border-zinc-700/50 ${i % 2 === 0 ? 'bg-zinc-900' : 'bg-zinc-800/50'}`}>
          <td class="py-3 px-4 text-zinc-400 font-medium">{key}</td>
          {products.map((p) => (
            <td class="py-3 px-4 text-zinc-200">{p.specs?.[key] ?? '—'}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
