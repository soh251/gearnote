---
interface Product {
  name: string;
  specs: Record<string, string>;
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;

const allKeys = [...new Set(products.flatMap((p) => Object.keys(p.specs ?? {})))];
---

<div class="overflow-x-auto rounded-xl border border-[#e5e7eb]">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-[#f5f5f5] border-b border-[#e5e7eb]">
        <th class="text-left py-3 px-4 text-[#6b7280] font-medium w-32">スペック</th>
        {products.map((p) => (
          <th class="text-left py-3 px-4 text-amber-600 font-semibold">{p.name}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {allKeys.map((key, i) => (
        <tr class={`border-b border-[#e5e7eb] ${i % 2 === 0 ? 'bg-white' : 'bg-[#f5f5f5]'}`}>
          <td class="py-3 px-4 text-[#6b7280] font-medium">{key}</td>
          {products.map((p) => (
            <td class="py-3 px-4 text-[#1a1a1a]">{p.specs?.[key] ?? '—'}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
